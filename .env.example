# Ditto V5 — API keys
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Rocket League ──────────────────────────────────────────────────
# Get from: https://ballchasing.com → Account → API key
BALLCHASING_TOKEN=your_ballchasing_token_here

# ── CS:GO / CS2 ────────────────────────────────────────────────────
# Get from: https://developers.faceit.com → My Apps → Create App → API Key
FACEIT_API_KEY=your_faceit_api_key_here

# ── LLM Judge ──────────────────────────────────────────────────────
# Required for real evaluation (not needed for --dry-run)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
